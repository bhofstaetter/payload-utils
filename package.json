{
    "name": "payload-utilities",
    "version": "1.0.0",
    "description": "Utility functions for Payload CMS — extract IDs, resolve documents, and compose field validators",
    "license": "MIT",
    "author": "Benedikt Hofstätter",
    "homepage": "https://github.com/bhofstaetter/payload-utilities",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bhofstaetter/payload-utilities.git"
    },
    "keywords": [
        "payload",
        "payloadcms",
        "utilities",
        "validation"
    ],
    "type": "module",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "typecheck": "tsc",
        "lint": "biome check",
        "lint:fix": "biome check --fix",
        "test": "vitest run",
        "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
    },
    "peerDependencies": {
        "payload": ">=3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.4",
        "payload": "^3.78.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^5",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
